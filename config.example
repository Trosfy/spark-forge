# forge runtime config. Searched in order (first found wins):
#   $FORGE_CONFIG  >  ~/.config/forge/config  >  /etc/forge/config
# Use /etc/forge/config for a system-wide install (e.g. when Claude Code runs as root).
# Per-key precedence: environment variable > config file > built-in default.
# Format: KEY=value (shell-sourceable; no spaces around '=').

# --- ComfyUI ---
FORGE_COMFY_URL=http://localhost:8188
FORGE_COMFY_CONTAINER=comfyui

# Host <-> container bind-mounted dirs. Leave UNSET to auto-detect from the
# container's mounts (docker inspect). Set them only for a non-Docker ComfyUI or a
# non-standard layout.
#FORGE_INPUT_DIR=/path/to/ComfyUI/input
#FORGE_OUTPUT_DIR=/path/to/ComfyUI/output
FORGE_COMFY_INPUT=/opt/ComfyUI/input
FORGE_COMFY_OUTPUT=/opt/ComfyUI/output

# --- Default model profile (models/<name>.json carries the weights + default params) ---
FORGE_MODEL=flux2-dev

# --- Hunyuan3D-2.1 (paths inside the ComfyUI container) ---
FORGE_HUNYUAN_REPO=/root/work/Hunyuan3D-2.1
FORGE_HY3D_CACHE=/root/.cache/hy3dgen

# --- S3 publishing ("acting as cloud") ---
FORGE_S3_BUCKET=
FORGE_S3_REGION=
FORGE_S3_PREFIX=forge
FORGE_AWS_PROFILE=
FORGE_S3_PUBLIC=false
# Optional CloudFront domain for stable, headless download URLs (the `cloudfront_domain`
# terraform output when enable_cloudfront=true). If set, publish_s3.sh --url uses it.
FORGE_CDN_DOMAIN=
